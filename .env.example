# ============================================================
# BACKEND: /backend/.env
# ============================================================

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/polok_portfolio
# OR: mongodb+srv://username:password@cluster.mongodb.net/polok_portfolio

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Admin credentials (used in seed script)
ADMIN_EMAIL=polok@admin.com
ADMIN_PASSWORD=Admin@12345

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# API URL (for file URLs in responses)
API_URL=http://localhost:5000

# Email (SMTP) - Optional for contact form notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
ADMIN_EMAIL_NOTIFY=polok@yourdomain.com

# Logging
LOG_LEVEL=info


# ============================================================
# FRONTEND: /frontend/.env.local
# ============================================================

NEXT_PUBLIC_API_URL=http://localhost:5000/api

# For production:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
